# pyannote needs a HuggingFace token + accepted licenses for
#   pyannote/speaker-diarization-community-1
HF_TOKEN=

MODEL_SIZE=medium
DEVICE=cpu
COMPUTE_TYPE=int8

MAX_DURATION_SECONDS=180
MAX_FILE_SIZE_MB=50

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-app.vercel.app

# Set to 1 to return canned output without loading models (flow testing only)
MOCK_PIPELINE=0
